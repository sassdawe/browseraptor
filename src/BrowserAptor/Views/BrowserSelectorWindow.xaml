<Window x:Class="BrowserAptor.Views.BrowserSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BrowserAptor"
        mc:Ignorable="d"
        Title="BrowserAptor – Choose Browser"
        Width="520"
        SizeToContent="Height"
        MinWidth="380"
        MinHeight="260"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        Icon="/Resources/browseraptor.ico"
        Background="#1E1E2E">

    <Window.Resources>
        <!-- Colour palette -->
        <SolidColorBrush x:Key="SurfaceBrush"     Color="#2A2A3C"/>
        <SolidColorBrush x:Key="AccentBrush"      Color="#7C5CBF"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#9370DB"/>
        <SolidColorBrush x:Key="ForegroundBrush"  Color="#CDD6F4"/>
        <SolidColorBrush x:Key="SubtleBrush"      Color="#6C7086"/>
        <SolidColorBrush x:Key="SelectedBrush"    Color="#313244"/>
        <SolidColorBrush x:Key="CancelBrush"      Color="#45475A"/>
        <SolidColorBrush x:Key="CancelHoverBrush" Color="#585B70"/>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ListBoxItem style -->
        <Style x:Key="BrowserItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background"         Value="Transparent"/>
            <Setter Property="Foreground"         Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="Padding"            Value="12,8"/>
            <Setter Property="Margin"             Value="0,1"/>
            <Setter Property="BorderThickness"    Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background"
                                        Value="{StaticResource SelectedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background"
                                        Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Profile tile button style (grid view) -->
        <Style x:Key="ProfileTileStyle" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Margin"          Value="0,0,6,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- View toggle button style -->
        <Style x:Key="ViewToggleStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource SubtleBrush}"/>
            <Setter Property="FontSize"        Value="16"/>
            <Setter Property="Width"           Value="28"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{StaticResource SelectedBrush}"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource ForegroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontSize"     Value="14"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="28,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{StaticResource SubtleBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button"
               BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource CancelBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource CancelHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: URL + view toggle -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Open link with"
                           Foreground="{StaticResource SubtleBrush}"
                           FontSize="12"
                           Margin="0,0,0,4"/>
                <TextBlock Text="{Binding Url}"
                           Foreground="{StaticResource ForegroundBrush}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding Url}"
                           MaxWidth="420"/>
            </StackPanel>

            <!-- Grid/List view toggle -->
            <Button Grid.Column="1"
                    Style="{StaticResource ViewToggleStyle}"
                    Command="{Binding ToggleViewCommand}"
                    VerticalAlignment="Bottom"
                    Margin="8,0,0,0">
                <Button.ToolTip>
                    <ToolTip>
                        <TextBlock>
                            <TextBlock.Text>
                                <Binding Path="IsGridView">
                                    <Binding.Converter>
                                        <local:BoolToStringConverter TrueValue="Switch to list view"
                                                                     FalseValue="Switch to grid view"/>
                                    </Binding.Converter>
                                </Binding>
                            </TextBlock.Text>
                        </TextBlock>
                    </ToolTip>
                </Button.ToolTip>
                <TextBlock>
                    <TextBlock.Text>
                        <Binding Path="IsGridView">
                            <Binding.Converter>
                                <local:BoolToStringConverter TrueValue="☰" FalseValue="⊞"/>
                            </Binding.Converter>
                        </Binding>
                    </TextBlock.Text>
                </TextBlock>
            </Button>
        </Grid>

        <!-- Separator -->
        <Separator Grid.Row="1"
                   Background="{StaticResource SurfaceBrush}"
                   Margin="0,0,0,12"/>

        <!-- LIST VIEW: flat list of browser + profile entries -->
        <ListBox Grid.Row="2"
                 x:Name="BrowserList"
                 ItemsSource="{Binding Entries}"
                 SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                 ItemContainerStyle="{StaticResource BrowserItemStyle}"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                 VirtualizingPanel.IsVirtualizing="False"
                 MouseDoubleClick="BrowserList_MouseDoubleClick"
                 PreviewMouseLeftButtonUp="BrowserList_PreviewMouseLeftButtonUp"
                 KeyDown="BrowserList_KeyDown"
                 Visibility="{Binding IsListView, Converter={StaticResource BoolToVis}}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Browser icon with channel badge overlay -->
                        <Grid Grid.Column="0"
                              Width="28" Height="28"
                              VerticalAlignment="Center">
                            <Image Width="28" Height="28"
                                   RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.Source>
                                    <Binding Path="ExePath"
                                             Converter="{x:Static local:ExeIconConverter.Instance}"/>
                                </Image.Source>
                            </Image>
                            <!-- Channel badge — visible only for Beta/Dev/Canary/Nightly -->
                            <Border CornerRadius="2"
                                    Padding="1,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Browser.Channel}" Value="Beta">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Setter Property="Background" Value="#E07700"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Browser.Channel}" Value="Dev">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Setter Property="Background" Value="#0D9488"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Browser.Channel}" Value="Canary">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Setter Property="Background" Value="#CA8A04"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Browser.Channel}" Value="Nightly">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Setter Property="Background" Value="#7C3AED"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Browser.Channel}"
                                           FontSize="5"
                                           FontWeight="Bold"
                                           Foreground="White"/>
                            </Border>
                        </Grid>

                        <!-- Display name, tinted by channel / incognito -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DisplayName}"
                                   Foreground="{Binding LabelColor,
                                               Converter={x:Static local:HexColorToBrushConverter.Instance}}"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- GRID VIEW: one row per browser, profile tiles as columns -->
        <ItemsControl Grid.Row="2"
                      x:Name="BrowserGrid"
                      ItemsSource="{Binding BrowserRows}"
                      Background="Transparent"
                      Focusable="False"
                      KeyDown="BrowserList_KeyDown"
                      Visibility="{Binding IsGridView, Converter={StaticResource BoolToVis}}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Browser name + icon -->
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top"
                                    Margin="0,4,8,0">
                            <!-- Icon with channel badge overlay -->
                            <Grid Width="20" Height="20"
                                  Margin="0,0,6,0"
                                  VerticalAlignment="Center">
                                <Image Width="20" Height="20"
                                       RenderOptions.BitmapScalingMode="HighQuality">
                                    <Image.Source>
                                        <Binding Path="ExePath"
                                                 Converter="{x:Static local:ExeIconConverter.Instance}"/>
                                    </Image.Source>
                                </Image>
                                <!-- Channel badge — visible only for Beta/Dev/Canary/Nightly -->
                                <Border CornerRadius="2"
                                        Padding="1,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Channel}" Value="Beta">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Setter Property="Background" Value="#E07700"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Channel}" Value="Dev">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Setter Property="Background" Value="#0D9488"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Channel}" Value="Canary">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Setter Property="Background" Value="#CA8A04"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Channel}" Value="Nightly">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Setter Property="Background" Value="#7C3AED"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Channel}"
                                               FontSize="5"
                                               FontWeight="Bold"
                                               Foreground="White"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="{Binding Name}"
                                       Foreground="{StaticResource ForegroundBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <!-- Profile tiles -->
                        <ItemsControl Grid.Column="1"
                                      ItemsSource="{Binding Profiles}"
                                      Focusable="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource ProfileTileStyle}"
                                            Command="{Binding LaunchCommand}"
                                            Background="{Binding TileBackground,
                                                         Converter={x:Static local:HexColorToBrushConverter.Instance}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Foreground="White"
                                                       Margin="0,0,4,0"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Text>
                                                    <Binding Path="Profile.IsIncognito">
                                                        <Binding.Converter>
                                                            <local:BoolToStringConverter TrueValue="⊘" FalseValue="●"/>
                                                        </Binding.Converter>
                                                    </Binding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Profile.Name}"
                                                       Foreground="White"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Footer buttons -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Cancel"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding CancelCommand}"/>

            <Button Grid.Column="2"
                    Content="Copy Link"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding CopyLinkCommand}"/>

            <Button Grid.Column="4"
                    Content="Open"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding OpenCommand}"
                    IsDefault="True"
                    Visibility="{Binding IsListView, Converter={StaticResource BoolToVis}}"/>
        </Grid>
    </Grid>
</Window>
